# Copy this file to .env and fill in your values
# Never commit .env to git

SECRET_KEY=change-this-to-a-random-string

# Supabase PostgreSQL connection string
# Find it at: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# MDS email — receives notifications when new requests are submitted
MDS_EMAIL=mds@surediagnostics.com

# Gmail SMTP — used to send notification emails
# Use a Gmail App Password: Google Account → Security → 2FA → App Passwords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=finance@surediagnostics.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=Sure Finance <finance@surediagnostics.com>
